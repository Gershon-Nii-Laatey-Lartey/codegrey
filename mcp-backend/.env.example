# Codegrey MCP Backend Environment Config

# The port this MCP backend runs on
MCP_PORT=3173

# Your Anthropic API Key (required for the agent loop)
ANTHROPIC_API_KEY=your_key_here

# Where to store MCP server configurations
# Defaults to ~/.codegrey/mcp-servers.json if not set
# MCP_STORE_PATH=./config/mcp-servers.json

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
