# AI IDE Backend — Environment Variables
# Copy this file to .env and fill in your values.
# The app is BYOK — the frontend passes keys per-request,
# so ANTHROPIC_API_KEY here is only needed for smoke tests.

# Optional: default Anthropic key for local testing
ANTHROPIC_API_KEY=

# Supabase project used by plan-mode model gateway
CODEGREY_SUPABASE_URL=https://fdizzpftrynhlaawsjpq.supabase.co
CODEGREY_SUPABASE_ANON_KEY=sb_publishable_i6MMYWQLq8nAup-pUj4iGw_ls3VcguL

# Server port (default: 3172)
PORT=3172

# Comma-separated list of allowed CORS origins
# Leave blank to allow all origins (fine for local Electron use)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
